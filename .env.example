# Copy this file to `.env`, then set the values in this first section for your environment.

# Optional report enrichment with OpenAI.
OPENAI_API_KEY=sk-your-key-here

# Optional Telegram timeline notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional app authentication.
APP_AUTH_USERNAME=ghostrecon
APP_AUTH_PASSWORD=change-this-password

# Hostnames and listener settings that may need local adjustment.
APP_BIND_HOST=127.0.0.1
APP_PORT=8000
ALLOWED_HOSTS=127.0.0.1,localhost,::1,ghostreconrev-app,ghostreconrev

# Optional Acunetix MCP integration values to align with your deployment.
# When GhostReconRev and MCPwnetix run together with Docker Compose, these usually point
# to `http://acunetix-mcp-server:3000` on the shared `dreamland` network.
ACUNETIX_MCP_URL=http://acunetix-mcp-server:3000/mcp
ACUNETIX_MCP_HEALTH_URL=http://acunetix-mcp-server:3000/healthz
# This token must match `ACUNETIX_MCP_AUTH_TOKEN` in `MCPwnetix/.env`.
ACUNETIX_MCP_AUTH_TOKEN=replace_with_shared_mcp_token
# Replace these example UUIDs with the Acunetix profile and report template you want to use.
ACUNETIX_DEFAULT_PROFILE_ID=11111111-1111-1111-1111-111111111111
ACUNETIX_DEFAULT_REPORT_TEMPLATE_ID=11111111-1111-1111-1111-111111111111
ACUNETIX_TARGET_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:87.0) Gecko/20100101 Firefox/87.0
# These proxy values are only used when `ACUNETIX_TARGET_PROXY_ENABLED=true`.
ACUNETIX_TARGET_PROXY_ADDRESS=192.168.167.1
ACUNETIX_TARGET_PROXY_PORT=1348

# The remaining values are predefined application and workflow defaults.
# Adjust them only if you need to tune behavior for your environment.

REPORT_LLM_MODEL=gpt-4.1-nano

TELEGRAM_TIMELINE_ENABLED=false
TELEGRAM_TIMEOUT=10

APP_MAX_REQUEST_BYTES=1048576
APP_REQUIRE_AUTH=false

ACUNETIX_MCP_TIMEOUT=60
ACUNETIX_TARGET_SCAN_SPEED=moderate
ACUNETIX_TARGET_CASE_SENSITIVE=yes
ACUNETIX_TARGET_PROXY_ENABLED=true
ACUNETIX_TARGET_PROXY_PROTOCOL=http
ACUNETIX_TARGET_CRITICALITY=0
ACUNETIX_RESULT_HISTORY_LIMIT=10
ACUNETIX_VULNERABILITIES_PAGE_LIMIT=99
ACUNETIX_SCAN_POLL_INTERVAL=10
ACUNETIX_SCAN_MAX_RUNTIME=14400
ACUNETIX_REPORT_POLL_INTERVAL=5
ACUNETIX_REPORT_TIMEOUT=300

# Collector tuning.
# Keep this `false` unless you explicitly want active enrichment tasks such as `nerva`.
ACTIVE_ENRICHMENT_ENABLED=false
# Minutes passed to `amass -timeout`.
AMASS_TIMEOUT=60
ASSETFINDER_TIMEOUT=60
CRTSH_TIMEOUT=20
DNSX_TIMEOUT=20
HOST_TIMEOUT=15
COLLECTOR_MAX_WORKERS=4
GAU_TIMEOUT=120
GAU_THREADS=10
GAU_MAX_WORKERS=5
NAABU_TIMEOUT=60
NAABU_MAX_WORKERS=5
NERVA_TIMEOUT=60
NERVA_MAX_WORKERS=5
HTTPX_TIMEOUT=45
HTTPX_MAX_WORKERS=8
HTTPX_MAX_REDIRECTS=2
